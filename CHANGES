<script>
  // ── Cursor ───────────────────────────────────────────────
  const cursor = document.getElementById('cursor');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top  = e.clientY + 'px';
  });

  // ── Petals ───────────────────────────────────────────────
  const field = document.getElementById('petalField');
  for (let i = 0; i < 22; i++) {
    const p = document.createElement('div');
    p.className = 'petal';
    p.style.left = Math.random() * 100 + '%';
    p.style.animationDuration = (6 + Math.random() * 10) + 's';
    p.style.animationDelay    = (Math.random() * 12) + 's';
    p.style.transform = `rotate(${Math.random()*360}deg) scale(${0.6 + Math.random()*0.8})`;
    const hue = Math.random() > 0.5 ? '#f9ddd8' : '#fbbcb6';
    p.style.background = `radial-gradient(ellipse at 40% 30%, ${hue}, #e8a09a)`;
    field.appendChild(p);
  }

  // ── Scroll animations ────────────────────────────────────
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

  // ── Wishes ───────────────────────────────────────────────
  const wishes = [];

  function esc(str) {
    return str
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderWishes() {
    const wall = document.getElementById('wishesWall');
    if (wishes.length === 0) {
      wall.innerHTML = '<div class="wishes-empty">Be the first to leave a wish for Bagdat ♡</div>';
      return;
    }
    wall.innerHTML = '';
    wishes.forEach((w, i) => {
      const card = document.createElement('div');
      card.className = 'wish-card';
      card.style.animationDelay = (i * 0.08) + 's';
      card.innerHTML = `
        <div class="wish-card-name">${w.emoji ? esc(w.emoji) + ' ' : ''}${esc(w.name)}</div>
        <div class="wish-card-text">${esc(w.polished)}</div>
        ${w.aiEnhanced ? '<span class="ai-badge">✦ polished with a little magic</span>' : ''}
      `;
      wall.appendChild(card);
    });
  }

  function showTyping() {
    const wall = document.getElementById('wishesWall');
    const t = document.createElement('div');
    t.className = 'typing-indicator'; t.id = 'typing';
    t.innerHTML = '<span></span><span></span><span></span>';
    wall.innerHTML = '';
    wall.appendChild(t);
  }
  function hideTyping() {
    const t = document.getElementById('typing');
    if (t) t.remove();
  }

  async function polishWish(name, text) {
    const prompt = `You are a warm, poetic assistant helping guests leave beautiful wishes for a bride named Bagdat at her bachelorette party.

A guest named "${name}" wrote:
"${text}"

Rewrite it as a single short, heartfelt, slightly poetic message (2–4 sentences). Keep the original sentiment. Make it warm, celebratory and elegant. Return ONLY the polished wish text — nothing else.`;

    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 200,
          messages: [{ role: 'user', content: prompt }]
        })
      });
      const data = await res.json();
      const txt = data.content && data.content[0] && data.content[0].text;
      if (txt) return { polished: txt.trim(), aiEnhanced: true };
    } catch (_) {}
    return { polished: text, aiEnhanced: false };
  }

  async function submitWish() {
    const nameEl  = document.getElementById('wishName');
    const textEl  = document.getElementById('wishText');
    const emojiEl = document.getElementById('wishEmoji');
    const btn     = document.getElementById('wishBtn');
    const errEl   = document.getElementById('wishError');

    const name  = nameEl.value.trim();
    const text  = textEl.value.trim();
    const emoji = emojiEl.value.trim();

    errEl.textContent = '';

    if (!name)          { errEl.textContent = 'Please enter your name 💕'; return; }
    if (text.length < 10) { errEl.textContent = 'Write at least a few words for Bagdat 🌸'; return; }

    btn.disabled = true;
    btn.textContent = 'Sprinkling magic…';

    document.getElementById('wishesWall').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    showTyping();

    const { polished, aiEnhanced } = await polishWish(name, text);

    hideTyping();
    wishes.unshift({ name, emoji, polished, aiEnhanced });
    renderWishes();

    nameEl.value = ''; textEl.value = ''; emojiEl.value = '';
    btn.disabled = false;
    btn.textContent = 'Send my wish 🌸';
  }

  renderWishes();
</script>
</body>
</html>
